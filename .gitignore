# ═══════════════════════════════════════════════════════════════════════
#  Namma Kelsa — Android .gitignore
# ═══════════════════════════════════════════════════════════════════════

# ── Gradle ───────────────────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# ── Android Studio / IntelliJ ────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.navigation/
captures/

# ── Local properties (SDK path, keys) ───────────────────────────────
local.properties

# ── Signing ──────────────────────────────────────────────────────────
*.jks
*.keystore
keystore.properties

# ── OS generated files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Kotlin ──────────────────────────────────────────────────────────
*.class
*.kotlin_module

# ── Logs ────────────────────────────────────────────────────────────
*.log

# ── APK / AAB output ────────────────────────────────────────────────
*.apk
*.ap_
*.aab

# ── NDK ─────────────────────────────────────────────────────────────
obj/

# ── Proguard ────────────────────────────────────────────────────────
proguard/

# ── Coverage / test reports ─────────────────────────────────────────
coverage/
*.exec
